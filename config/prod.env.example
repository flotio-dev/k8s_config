# Copy this file to config/prod.env, then edit local values.
# Do not commit config/prod.env.

# Proxmox API
PROXMOX_ENDPOINT=https://192.168.1.16:8006/
PROXMOX_API_TOKEN=terraform@pve!terraform=REPLACE_ME
PROXMOX_INSECURE=true
PROXMOX_NODE_NAME=pve

# Proxmox storage and template
TEMPLATE_VM_ID=9000
VM_DATASTORE_ID=local-lvm
# Datastore used by the provider for the cloud-init disk. It must support
# content type "images"; local-lvm is usually correct, plain local often is not.
SNIPPET_DATASTORE_ID=local-lvm
VM_BRIDGE=vmbr0
VM_VLAN_ID=


# Network
IPV4_GATEWAY=192.168.1.1
DNS_SERVERS=["1.1.1.1","8.8.8.8"]

# VM addresses, with CIDR prefix.
K8S_CP_01_VM_ID=800
K8S_WORKER_01_VM_ID=801
K8S_WORKER_02_VM_ID=802
K8S_WORKER_03_VM_ID=803

K8S_CP_01_IP_CIDR=192.168.1.10/24
K8S_WORKER_01_IP_CIDR=192.168.1.11/24
K8S_WORKER_02_IP_CIDR=192.168.1.12/24
K8S_WORKER_03_IP_CIDR=192.168.1.13/24

# VM sizing.
K8S_CP_01_CPU=4
K8S_CP_01_MEMORY_MB=6144
K8S_CP_01_DISK_GB=60

K8S_WORKER_01_CPU=8
K8S_WORKER_01_MEMORY_MB=12288
K8S_WORKER_01_DISK_GB=120

K8S_WORKER_02_CPU=8
K8S_WORKER_02_MEMORY_MB=12288
K8S_WORKER_02_DISK_GB=120

K8S_WORKER_03_CPU=8
K8S_WORKER_03_MEMORY_MB=12288
K8S_WORKER_03_DISK_GB=120

# Cloud-init / Ansible SSH user.
CI_USERNAME=ansible
SSH_PUBLIC_KEY=ssh-ed25519 AAAA_REPLACE_ME user@host

# Optional: avoid interactive --ask-vault-pass by pointing to a local password file.
ANSIBLE_VAULT_PASSWORD_FILE=

# Ansible platform configuration.
PROJECT_NAME=flotio
ENV_NAME=prod
TIMEZONE=Europe/Paris
KUBERNETES_VERSION=1.34
# Optional. Defaults to stable-${KUBERNETES_VERSION}; set to v1.34.x to pin exactly.
KUBERNETES_KUBEADM_VERSION=
KUBERNETES_POD_CIDR=10.244.0.0/16
KUBERNETES_SERVICE_CIDR=10.96.0.0/12
FLANNEL_VERSION=0.26.5
FLANNEL_NAMESPACE=kube-flannel

# Keep MetalLB disabled during the first bootstrap. Install it after the
# cluster network is stable with: make ansible-metallb
METALLB_ENABLED=false
METALLB_VERSION=0.14.9
METALLB_NAMESPACE=metallb-system
METALLB_POOL_NAME=gpe-pool
METALLB_L2_ADVERTISEMENT_NAME=gpe-l2
METALLB_ADDRESSES=192.168.1.230-192.168.1.245

LONGHORN_ENABLED=true
LONGHORN_VERSION=1.11.1
LONGHORN_NAMESPACE=longhorn-system
LONGHORN_WAIT_TIMEOUT=600s

# GHCR image pull secret for private GitHub Container Registry images.
# Use a GitHub token with read:packages access.
GHCR_PULL_SECRET_ENABLED=true
GHCR_REGISTRY=ghcr.io
GHCR_USERNAME=REPLACE_ME
GHCR_TOKEN=REPLACE_ME
GHCR_EMAIL=REPLACE_ME
GHCR_SECRET_NAME=ghcr-secret
GHCR_SECRET_NAMESPACES=dev,prod

ANDROID_BUILD_ENABLED=true
ANDROID_BUILD_NAMESPACE=android-build
ANDROID_BUILD_SERVICE_ACCOUNT_TOKEN_SECRET=android-builder-token
ANDROID_BUILD_CORE_API_TOKEN_SECRET=core-api-k8s-token
ANDROID_BUILD_TOKEN_TARGET_NAMESPACES=dev,prod

INGRESS_NGINX_ENABLED=true
INGRESS_NGINX_VERSION=1.12.1
INGRESS_NGINX_NAMESPACE=ingress-nginx

CERT_MANAGER_ENABLED=true
CERT_MANAGER_VERSION=1.17.2
CERT_MANAGER_NAMESPACE=cert-manager
CERT_MANAGER_EMAIL=clain_b@etna-alternance.net

ARGOCD_ENABLED=true
ARGOCD_VERSION=2.14.4
ARGOCD_NAMESPACE=argocd

MONITORING_ENABLED=true
MONITORING_NAMESPACE=monitoring
MONITORING_INSTALL_HELM=true
MONITORING_APPLY_PVE_EXPORTER=false

# Rollout / wait timeouts.
METALLB_WAIT_TIMEOUT=180s
INGRESS_NGINX_WAIT_TIMEOUT=240s
CERT_MANAGER_WAIT_TIMEOUT=240s
ARGOCD_WAIT_TIMEOUT=300s
MONITORING_WAIT_TIMEOUT=300s
POSTFLIGHT_NODE_READY_TIMEOUT=300s
